<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookNest – Online Könyváruház</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>

    <!-- Navigációs sáv -->
    <nav class="navbar">
      <div class="nav-container">
        <%= link_to "BookNest", root_path, class: "nav-logo" %>
        <ul class="nav-links">
          <li><%= link_to "Főoldal",    root_path,  class: "nav-link #{'active' if current_page?(root_path)}" %></li>
          <li><%= link_to "Könyvek",    books_path, class: "nav-link #{'active' if current_page?(books_path)}" %></li>
          <li>
            <%= link_to cart_path, class: "nav-link nav-cart" do %>
              🛒 Kosár
              <% if cart_count > 0 %>
                <span class="cart-badge"><%= cart_count %></span>
              <% end %>
            <% end %>
          </li>
          <% if logged_in? %>
            <li><%= link_to "👤 #{current_user.name}", edit_user_path(current_user), class: "nav-link" %></li>
            <li><%= link_to "Kijelentkezés", logout_path, class: "nav-link" %></li>
          <% else %>
            <li><%= link_to "Bejelentkezés", login_path, class: "nav-link nav-btn" %></li>
          <% end %>
        </ul>
      </div>
    </nav>

    <!-- Flash üzenetek -->
    <div class="flash-container">
      <% if flash[:notice] %>
        <div class="flash flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash flash-alert"><%= flash[:alert] %></div>
      <% end %>
    </div>

    <!-- Fő tartalom -->
    <main class="main-content">
      <%= yield %>
    </main>

    <!-- Lábléc -->
    <footer class="footer">
      <div class="footer-container">
        <div class="footer-col">
          <h4>BookNest</h4>
          <p>Az Ön megbízható online könyváruháza.</p>
        </div>
        <div class="footer-col">
          <h4>Linkek</h4>
          <ul>
            <li><%= link_to "Főoldal",  root_path %></li>
            <li><%= link_to "Könyvek",  books_path %></li>
            <li><a href="#">ÁSZF</a></li>
            <li><a href="#">Adatvédelem</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Kapcsolat</h4>
          <p>info@booknest.hu</p>
          <p>+36 1 234 5678</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025 BookNest. Minden jog fenntartva.</p>
      </div>
    </footer>

  </body>
</html>
