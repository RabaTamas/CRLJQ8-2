<!-- Kenyérmorzsa -->
<nav class="breadcrumb">
  <div class="container">
    <%= link_to "BookNest", root_path %> &rsaquo;
    <%= link_to "Bejelentkezés", login_path %> &rsaquo;
    <span>Regisztráció</span>
  </div>
</nav>

<section class="section">
  <div class="container container-narrow">
    <div class="auth-card">
      <h1>Regisztráció</h1>

      <%= form_with model: @user, url: users_path, local: true do |f| %>
        <% if @user.errors.any? %>
          <div class="error-box">
            <ul>
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= f.label :name, "Teljes név" %>
          <%= f.text_field :name, class: "form-input", placeholder: "Kovács János", required: true %>
        </div>

        <div class="form-group">
          <%= f.label :email, "Email cím" %>
          <%= f.email_field :email, class: "form-input", placeholder: "pelda@email.hu", required: true %>
        </div>

        <div class="form-group">
          <%= f.label :password, "Jelszó" %>
          <%= f.password_field :password, class: "form-input", placeholder: "Legalább 6 karakter", required: true %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Jelszó megerősítése" %>
          <%= f.password_field :password_confirmation, class: "form-input", placeholder: "••••••••", required: true %>
        </div>

        <%= f.submit "Regisztráció", class: "btn btn-success btn-full" %>
      <% end %>

      <div class="auth-divider"><span>vagy</span></div>

      <div class="auth-footer">
        <p>Már van fiókja?</p>
        <%= link_to "Bejelentkezés", login_path, class: "btn btn-outline btn-full" %>
      </div>
    </div>
  </div>
</section>
