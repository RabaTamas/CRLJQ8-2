<!-- Kenyérmorzsa -->
<nav class="breadcrumb">
  <div class="container">
    <%= link_to "BookNest", root_path %> &rsaquo;
    <span>Bejelentkezés</span>
  </div>
</nav>

<section class="section">
  <div class="container container-narrow">
    <div class="auth-card">
      <h1>Bejelentkezés</h1>

      <%= form_with url: session_path, method: :post, local: true do |f| %>
        <div class="form-group">
          <%= label_tag :email, "Email cím" %>
          <%= email_field_tag :email, params[:email], class: "form-input",
                placeholder: "pelda@email.hu", required: true, autofocus: true %>
        </div>

        <div class="form-group">
          <%= label_tag :password, "Jelszó" %>
          <%= password_field_tag :password, nil, class: "form-input",
                placeholder: "••••••••", required: true %>
        </div>

        <div class="form-group form-check">
          <%= check_box_tag :remember_me %>
          <%= label_tag :remember_me, "Emlékezz rám" %>
          <a href="#" class="link-right">Elfelejtett jelszó?</a>
        </div>

        <%= submit_tag "Bejelentkezés", class: "btn btn-primary btn-full" %>
      <% end %>

      <div class="auth-divider"><span>vagy</span></div>

      <div class="auth-footer">
        <p>Még nincs fiókja?</p>
        <%= link_to "Regisztráció", register_path, class: "btn btn-success btn-full" %>
      </div>
    </div>
  </div>
</section>
